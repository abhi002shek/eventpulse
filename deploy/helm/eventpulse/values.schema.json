{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "resources", "securityContext", "podSecurityContext"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(:latest|:stable)$"
          }
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "ClusterIP"
        }
      }
    },
    "monitoring": {
      "type": "object",
      "required": ["enabled", "prometheusNamespace", "serviceMonitor", "prometheusRule"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "prometheusNamespace": {
          "type": "string",
          "minLength": 1
        },
        "serviceMonitor": {
          "type": "object",
          "required": ["enabled", "interval", "scrapeTimeout", "labels"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "type": "string",
              "minLength": 1
            },
            "scrapeTimeout": {
              "type": "string",
              "minLength": 1
            },
            "labels": {
              "type": "object"
            }
          }
        },
        "prometheusRule": {
          "type": "object",
          "required": ["enabled", "labels", "latencyThresholdSeconds", "highErrorRatio"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "labels": {
              "type": "object"
            },
            "latencyThresholdSeconds": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "highErrorRatio": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["enabled", "className", "path", "pathType", "annotations"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "pathType": {
          "type": "string",
          "enum": ["Prefix", "Exact", "ImplementationSpecific"]
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "resources": {
      "type": "object",
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "required": ["cpu", "memory"]
        },
        "limits": {
          "type": "object",
          "required": ["cpu", "memory"]
        }
      }
    },
    "securityContext": {
      "type": "object",
      "required": ["allowPrivilegeEscalation", "privileged", "readOnlyRootFilesystem", "runAsNonRoot", "runAsUser", "capabilities"],
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "privileged": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 1
        },
        "capabilities": {
          "type": "object",
          "required": ["drop"],
          "properties": {
            "drop": {
              "type": "array",
              "contains": {
                "const": "ALL"
              }
            }
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "required": ["runAsNonRoot", "runAsUser", "seccompProfile"],
      "properties": {
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 1
        },
        "seccompProfile": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "RuntimeDefault"
            }
          }
        }
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "apiIngressCidrs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          }
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["host", "port", "name", "user", "secret"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "sslMode": {
          "type": "string",
          "enum": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"]
        },
        "secretName": {
          "type": "string",
          "minLength": 1
        },
        "usernameKey": {
          "type": "string"
        },
        "passwordKey": {
          "type": "string",
          "minLength": 1
        },
        "secret": {
          "type": "object",
          "required": ["name", "passwordKey"],
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "usernameKey": {
              "type": "string"
            },
            "passwordKey": {
              "type": "string",
              "minLength": 1
            },
            "password": {
              "type": "string"
            }
          }
        },
        "externalSecret": {
          "type": "object",
          "required": ["enabled", "secretProviderClassName", "mountPath"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "secretProviderClassName": {
              "type": "string"
            },
            "secretArn": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "usePodIdentity": {
              "type": "string",
              "enum": ["true", "false"]
            },
            "mountPath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "networkPolicyEgressCidrs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
          }
        }
      }
    }
  }
}
