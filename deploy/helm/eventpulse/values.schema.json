{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "resources", "securityContext", "podSecurityContext"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(:latest|:stable)$"
          }
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "ClusterIP"
        }
      }
    },
    "resources": {
      "type": "object",
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "required": ["cpu", "memory"]
        },
        "limits": {
          "type": "object",
          "required": ["cpu", "memory"]
        }
      }
    },
    "securityContext": {
      "type": "object",
      "required": ["allowPrivilegeEscalation", "privileged", "readOnlyRootFilesystem", "runAsNonRoot", "runAsUser", "capabilities"],
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "privileged": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 1
        },
        "capabilities": {
          "type": "object",
          "required": ["drop"],
          "properties": {
            "drop": {
              "type": "array",
              "contains": {
                "const": "ALL"
              }
            }
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "required": ["runAsNonRoot", "runAsUser", "seccompProfile"],
      "properties": {
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 1
        },
        "seccompProfile": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "RuntimeDefault"
            }
          }
        }
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["host", "port", "name", "user", "secret"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "secret": {
          "type": "object",
          "required": ["name", "passwordKey"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "passwordKey": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
