      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"eventpulse\", container=\"api\"}[5m])) / sum(kube_pod_container_resource_requests{namespace=\"eventpulse\", container=\"api\", resource=\"cpu\"})",
          "legendFormat": "cpu usage/request"
        }
      ],
      "title": "CPU Usage Against Request",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"eventpulse\", container=\"api\"})",
          "legendFormat": "working set"
        }
      ],
      "title": "Memory Working Set",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"eventpulse\", container=\"api\"}[1h])",
          "legendFormat": "{{pod}}"
        }
      ],
